<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Panda_Booster_V2"
        xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" x:Class="Panda_Booster_V2.MainWindow"
        mc:Ignorable="d"
        Title="Panda Ping-Booster V2" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" Unloaded="Window_Unloaded"  Height="333.45" Width="607.168" AllowsTransparency="True" WindowStyle="None" Background="{x:Null}" Icon="Pandabooster.png">
    <Window.Resources>
        <Style TargetType="{x:Type RadioButton}" x:Key="APISelectionn">
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Grid>
                            <Border x:Name="OKK" Height="24" Background="#FFACACAC" CornerRadius="10" Width="44">
                                <Border x:Name="Checl" Background="White" Height="20" Width="20" CornerRadius="12" HorizontalAlignment="Left" Margin="2 0 0 0">
                                    <Label x:Name="SHIT"   Background="Transparent" BorderThickness="0" Content="&#xE5CD;" Foreground="#bebebe" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="/Panda Ping-Booster;component/Fonts/#Material Icons Round"/>
                                </Border>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="OKK"
                                                Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)"
                                                To="#8dd6ea"
                                                Duration="00:00:00.3">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation
                                                Storyboard.TargetName="SHIT"
                                                Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                To="#8dd6ea"
                                                Duration="00:00:00.3">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ThicknessAnimation
                                                Storyboard.TargetName="Checl"
                                                Storyboard.TargetProperty="Margin"
                                                To="22 0 0 0"
                                                Duration="00:00:00.3">
                                                <ThicknessAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetName="OKK"
                                                Storyboard.TargetProperty="(Control.Background).(SolidColorBrush.Color)"
                                                To="#bebebe"
                                                Duration="00:00:00.3">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation
                                                Storyboard.TargetName="SHIT"
                                                Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                To="#bebebe"
                                                Duration="00:00:00.3">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ThicknessAnimation
                                                Storyboard.TargetName="Checl"
                                                Storyboard.TargetProperty="Margin"
                                                To="2 0 0 0"
                                                Duration="00:00:00.3">
                                                <ThicknessAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Content" Value="&#xE876;" TargetName="SHIT"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Content" Value="&#xE5CD;" TargetName="SHIT"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="15" Background="#FF161616">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="175*"/>
                <RowDefinition Height="111*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Wpf:WebView2 HorizontalAlignment="Left" Height="261" Margin="308,49,0,-106" VerticalAlignment="Top" Width="289" Source="https://ravenscosmoid.com/iLcQgFgz18JlsuG/63013"/>
            </Grid>
            <Border x:Name="UI_DragHandle" CornerRadius="15" Margin="0,0,0,174" Background="#FF181818" MouseDown="UI_DragHandle_MouseDown"/>
            <Grid Margin="0,16,0,166" MouseDown="UI_DragHandle_MouseDown" Background="#FF181818"/>
            <Label Content="Panda Booster V2" Foreground="White" Margin="10,0,416,166" FontFamily="Teko" FontSize="18"/>
            <Border x:Name="Exitbtn" CornerRadius="15" BorderThickness="1" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="19" Margin="578,10,0,0" Background="#FFCD0E0E" MouseDown="Exitbtn_MouseDown"  RenderTransformOrigin="12.084,0.71"/>
            <Border x:Name="Minimize" CornerRadius="15" BorderThickness="1" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="19" Margin="554,10,0,0" Background="#FFCD990E" MouseDown="Minimize_MouseDown"  RenderTransformOrigin="12.084,0.71"/>
            <RadioButton Checked="ServerSelecton_Checked" x:Name="DefaultServer" Style="{DynamicResource APISelectionn}" Margin="16,52,526,124"/>
            <Label Content="Original Server" Foreground="White" Margin="73,52,448,123" FontFamily="Teko Medium" FontSize="15"/>
            <RadioButton x:Name="ServerOne" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="16,85,526,92"/>
            <Label Content="Server #1" Foreground="White" Margin="74,82,470,95" FontFamily="Teko Medium" FontSize="15" RenderTransformOrigin="0.5,0.5">
                <Label.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="0.026"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Label.RenderTransform>
            </Label>
            <RadioButton x:Name="ServerTwo" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="16,117,526,60"/>
            <Label Content="Server #2" Foreground="White" Margin="74,115,470,60" FontFamily="Teko Medium" FontSize="15"/>
            <RadioButton x:Name="ServerThree" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="17,149,525,22"/>
            <Label Content="Server #3" Foreground="White" Margin="74,150,469,28" FontFamily="Teko Medium" FontSize="15"/>
            <RadioButton x:Name="ServerFour" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="159,52,392,124"/>
            <Label Content="Server #4" Foreground="White" Margin="220,52,317,123" FontFamily="Teko Medium" FontSize="15"/>
            <RadioButton x:Name="ServerFive" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="159,83,392,89"/>
            <Label Content="Server #5" Foreground="White" Margin="220,86,326,93" FontFamily="Teko Medium" FontSize="15"/>
            <RadioButton x:Name="ServerSix" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="159,118,392,57"/>
            <Label Content="Server #6" Foreground="White" Margin="218,118,323,58" FontFamily="Teko Medium" FontSize="15"/>

            <RichTextBox x:Name="ConsoleBox" Margin="10,25,304,22" Background="#FF212121" IsReadOnly="True" Foreground="White" Grid.Row="1" IsDocumentEnabled="True" FontSize="9"/>

            <Label Margin="10,5,450,79" Content="Console" Foreground="White" Grid.Row="1" FontSize="10"/>
            <RadioButton x:Name="ServerSeven" Checked="ServerSelecton_Checked" Style="{DynamicResource APISelectionn}" Margin="159,151,392,25"/>
            <Label Content="Server #7" Foreground="White" Margin="218,151,330,27" FontFamily="Teko Medium" FontSize="15"/>
            <Label Content="Panda-Pelican Development. All Right in Service" Foreground="White" Margin="468,110,10,-7" FontFamily="Teko Medium" FontSize="7" Grid.Row="1" Opacity="0.2"/>

        </Grid>
    </Border>
</Window>
