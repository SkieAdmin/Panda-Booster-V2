<Window x:Class="Panda_Booster_V2.KeySystem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Panda_Booster_V2"
        mc:Ignorable="d"
        Title="Panda Ping-Booster V2" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded"  Height="186.95" Width="518.168" AllowsTransparency="True" WindowStyle="None" Background="{x:Null}" Icon="Pandabooster.png">
    <Border CornerRadius="15" Background="#FF161616">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="175*"/>
                <RowDefinition Height="111*"/>
            </Grid.RowDefinitions>
            <Border x:Name="UI_DragHandle" CornerRadius="15" Margin="0,0,0,79" Background="#FF181818" MouseDown="UI_DragHandle_MouseDown"></Border>
            <Grid Margin="0,16,0,79" MouseDown="UI_DragHandle_MouseDown" Background="#FF181818"></Grid>
            <Label Content="Panda Booster V2" Foreground="White" Margin="10,3,370,84" FontFamily="Teko" FontSize="15"></Label>
            <Border x:Name="Exitbtn" CornerRadius="15" BorderThickness="1" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="19" Margin="484,7,0,0" Background="#FFCD0E0E" MouseDown="Exitbtn_MouseDown"  RenderTransformOrigin="12.084,0.71"/>
            <Border x:Name="Minimize" CornerRadius="15" BorderThickness="1" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="19" Margin="460,7,0,0" Background="#FFCD990E" MouseDown="Minimize_MouseDown"  RenderTransformOrigin="12.084,0.71"/>
            <Label Content="Before we get started, please enter your key or if you don't have a key then click get key." Foreground="White" Margin="41,49,39,35" FontFamily="Teko Medium" FontSize="15"/>
            <TextBox x:Name="KeyInput" Margin="29,84,15,10" RenderTransformOrigin="0.5,0.5" Background="{x:Null}" Foreground="White" Text="KEY GOES HERE"/>
            <Button x:Name="GetKeyBTN" Click="GetKeyBTN_Click"  Margin="246,109,150,48" Background="{x:Null}" Content="Get Key" Foreground="White" FontFamily="Teko" FontSize="14" Grid.RowSpan="2"/>
            <Button x:Name="ValidateKeyBTN" Click="ValidateKeyBTN_Click" Margin="381,109,15,48" Background="{x:Null}" Content="Enter" Foreground="White" FontFamily="Teko" FontSize="14" Grid.RowSpan="2"/>
        </Grid>
    </Border>
</Window>
